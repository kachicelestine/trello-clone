# ── Clerk (https://dashboard.clerk.com) ───────────────────────────────────────
# Publishable key — safe to expose in browser bundles
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# Secret key — server-side only, never expose
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/

# ── Database ──────────────────────────────────────────────────────────────────
# Local dev:    mysql://root:changeme@localhost:3306/trello_clone
# PlanetScale:  mysql://user:pass@host/db?sslaccept=strict
# Docker:       overridden by docker-compose.yml — leave as-is
DATABASE_URL=mysql://root:changeme@localhost:3306/trello_clone

# ── Unsplash (https://unsplash.com/developers) ────────────────────────────────
NEXT_PUBLIC_UNSPLASH_ACCESS_KEY=...

# ── Stripe (https://dashboard.stripe.com/apikeys) ────────────────────────────
STRIPE_API_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── App ───────────────────────────────────────────────────────────────────────
# Used by Stripe webhooks and Clerk redirect URLs — must be your public URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Docker-compose only ───────────────────────────────────────────────────────
# MySQL root password used by the db service
MYSQL_ROOT_PASSWORD=changeme
